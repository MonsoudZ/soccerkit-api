# Server
ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soccerkit?sslmode=disable

# JWT — generate a strong random value for anything deployed (`openssl rand -hex 32`).
# A deployed process refuses to boot with a placeholder or a secret under 32 bytes.
#
# There is no JWT_REFRESH_SECRET: refresh tokens are opaque random strings stored
# as rows, not JWTs, so there is nothing to sign them with.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Sign in with Apple (iOS app auth).
#  - APPLE_CLIENT_ID: the app's bundle identifier (the identity token's `aud`).
#  - DEV_APPLE_BYPASS=true: skip Apple signature verification for LOCAL DEV only.
# Set APPLE_CLIENT_ID and leave DEV_APPLE_BYPASS unset in production.
APPLE_CLIENT_ID=
DEV_APPLE_BYPASS=true

# CORS — comma-separated origins, or * for all
CORS_ORIGINS=*
